choose-if: admin_cap >= sec_hounds_establishcost
subtitle: Requires [+ sec_hounds_establishcost +] bureaucratic effort
unavailable-subtitle: We need better bureaucracy!
on-arrival: {!
    Q.sec.hounds.level = 1
    Q.sec_hounds_level = 1
!}

- @security: Back

@expand_hounds
title: Expand Royal Yeomanry
new-page: true
view-if: sec_hounds_established >= 1
choose-if: admin_cap >= sec_ss_establishcost
subtitle: Requires [+ sec_ss_expand +] bureaucratic effort
unavailable-subtitle: We need better bureaucracy!
on-arrival: {!
    Q.sec.hounds.level += 1
    Q.sec_hounds_level += 1    
!}

