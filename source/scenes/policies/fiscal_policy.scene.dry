title: Fiscal policy
new-page: true
on-arrival: {!

Object.entries(Q.taxes).forEach((tax) => {
    if (tax.active) {
        let base = 0;
        Object.entries(Q.provinces).forEach((prov) => {
            if (tax.metrics.includes("pop")){
                base += prov.pop * prov.control
            }
            if (tax.metrics.includes("land")){
                base += prov.land * prov.control
            }
            if (tax.metrics.includes("wealth")){
                base += prov.wealth * prov.control
            }
            if (tax.metrics.includes("trade")){
                base += prov.trade * prov.control
            }
            if (tax.metrics.includes("novigrad_trade") && ("novigrad_trade" in prov)){
                base += prov.novigrad_trade * prov.control
            }
        })
        base /= tax.metrics.length  
        rev = Math.round(base * tax.base * tax.rate * tax.eff) / 100
        
        Q.taxes[tax.id].rev = rev
        Q.budget_balance += rev
    }
});

Q.budget_balance = Math.round(Q.budget_balance * 10) / 10;

!}

= Fiscal policy


<table>
<tr><th>Current taxes:</th></tr>
[? if taxes_vassals_active == 1 : <tr><td style="table-label"> Feudal duties</td><td style="table-value"> [+ taxes_vassals_rev +]&nbsp;thousand crowns</td></tr> ?]
[? if taxes_cities_active == 1 : <tr><td style="table-label"> City duties</td><td style="table-value"> [+ taxes_cities_rev +]&nbsp;thousand crowns</td></tr> ?]
[? if taxes_poll_active == 1 : <tr><td style="table-label"> Poll tax</td><td style="table-value"> [+ taxes_poll_rev +]&nbsp;thousand crowns</td></tr> ?]
[? if taxes_land_active == 1 : <tr><td style="table-label"> Land tax</td><td style="table-value"> [+ taxes_land_rev +]&nbsp;thousand crowns</td></tr> ?]
[? if taxes_houses_active == 1 : <tr><td style="table-label"> Window tax</td><td style="table-value"> [+ taxes_houses_rev +]&nbsp;thousand crowns</td></tr> ?]
[? if taxes_consum_active == 1 : <tr><td style="table-label"> Luxury goods taxes</td><td style="table-value"> [+ taxes_consum_rev +]&nbsp;thousand crowns</td></tr> ?]
[? if taxes_income_active == 1 : <tr><td style="table-label"> Income tax</td><td style="table-value"> [+ taxes_income_rev +]&nbsp;thousand crowns</td></tr> ?]
[? if taxes_tithe_active == 1 : <tr><td style="table-label"> Royal tithe</td><td style="table-value"> [+ taxes_tithe_rev +]&nbsp;thousand crowns</td></tr> ?]
<tr><th>Current tolls:</th></tr>
[? if taxes_toll_novigrad_active == 1 : <tr><td style="table-label"> Toll on Pontar river in Novigrad</td><td style="table-value"> [+ taxes_toll_novigrad_rev +]&nbsp;thousand crowns</td></tr> ?]
[? if taxes_tolls_active == 1 : <tr><td style="table-label"> Other tolls</td><td style="table-value"> [+ taxes_tolls_rev +]&nbsp;thousand crowns</td></tr> ?]
</table>

- @change_taxes: Adjust current taxes
- @new_taxes: Introduce new taxes
- @tolls: Adjust tolls
- @dijkstra: Back

@change_taxes
title: Adjust taxes

- @vassals_tax: Adjust feudal duties
- @cities_tax: Adjust city duties
- @poll_tax: Adjust poll tax
- @land_tax: Adjust land tax
- @houses_tax: Adjust window tax
- @income_tax: Adjust income tax
- @consum_tax: Adjust good taxes
- @fiscal_policy: Back

@vassals_tax
title: Adjust feudal duties
view-if: {! Q.taxes["vassals"].active !}
on-arrival: {! Q.tax_changed = "vassals";
Q.name = Q.taxes[Q.tax_changed].name.toUpperCase() !}
new-page: true

= [+ name +]

[+ taxes_vassals_desc +]

Current revenue: [+ taxes_vassals_rev +]&nbsp;thousand crowns

Current rate: [+ taxes_vassals_rate : tax_rates +]

Current efficacy: [+ taxes_vassals_eff : tax_eff +]

- @increase_tax: Increase rates
- @decrease_tax: Decrease rates
- @change_taxes: Back

